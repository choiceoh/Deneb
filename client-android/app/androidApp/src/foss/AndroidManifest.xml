<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      SMS read/send are opt-in, FOSS-only features. These permissions are intentionally
      declared only in the `foss` product flavor so the Play Store variant never
      requests them (Play policy restricts READ_SMS and SEND_SMS to default SMS
      handlers). The SMS feature gates itself at runtime on READ_SMS being declared
      in the merged manifest, so the Play variant never shows the feature at all.
      Read and send are independent user opt-ins at runtime.
    -->
    <uses-permission android:name="android.permission.READ_SMS"/>
    <uses-permission android:name="android.permission.SEND_SMS"/>

    <!--
      Contacts read is FOSS-only for the same privacy reason as SMS. It enriches
      people already in the wiki (phone/email/org) and feeds the ASR proper-noun
      bias; it never uploads the whole address book as new entries. The feature
      gates itself at runtime by probing for READ_CONTACTS in the merged manifest,
      so the Play Store variant never shows it.
    -->
    <uses-permission android:name="android.permission.READ_CONTACTS"/>

    <!--
      Location sensing (FOSS-only): an on-demand FusedLocationProvider read, forwarded
      (throttled) to the gateway as a location_update so phone_read("location") answers
      from cache without an SSH round-trip. FINE/COARSE only — no background location
      (the read happens while the app is active, on sync). Declared in foss only so the
      Play Store variant never requests it; readCurrentLocation gates at runtime on the
      permission being granted.
    -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>

    <!--
      Usage-rhythm sensing (FOSS-only): reads recent app-usage on-device, compresses
      it to a coarse work-rhythm digest, and forwards it — throttled — to the gateway's
      proactive judgment (default-silence; only a genuine work signal surfaces). Like
      Notification access, this is a special-access permission the user grants in
      Settings (Special app access > Usage access); the declaration just makes Deneb
      eligible. tools:ignore silences the lint warning for this protected permission.
    -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!--
      Notification sensing (FOSS-only): the launcher's background information-gathering
      service. Reads posted notifications, drops noise + security-sensitive ones
      on-device, and forwards signal candidates to the gateway's proactive judgment
      (which suppresses OTP/spam/routine and surfaces only signal). Requires the user
      to grant Notification access (Settings > Notification access) — that grant is
      the explicit opt-in; BIND_NOTIFICATION_LISTENER_SERVICE is held by the system.
      The empty <application> merges this <service> into the main manifest's app.
    -->
    <application>
        <service
            android:name="ai.deneb.DenebNotificationListenerService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>
    </application>

</manifest>
