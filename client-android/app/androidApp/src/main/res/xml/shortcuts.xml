<?xml version="1.0" encoding="utf-8"?>
<!-- Long-press the Deneb icon -> 음성 캡처: speak, and the transcript goes to chat. -->
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut
        android:shortcutId="voice_capture"
        android:enabled="true"
        android:shortcutShortLabel="@string/shortcut_voice_short"
        android:shortcutLongLabel="@string/shortcut_voice_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:data="deneb://voice"
            android:targetPackage="com.inspiredandroid.kai"
            android:targetClass="com.inspiredandroid.kai.MainActivity" />
    </shortcut>
</shortcuts>
