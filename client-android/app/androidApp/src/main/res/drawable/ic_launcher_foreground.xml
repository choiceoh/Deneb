<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="512"
    android:viewportHeight="512">
  <!-- Deneb mark: an 8-point sparkle-star on a WHITE adaptive-icon background,
       FACETED for depth. Eight tips (four long N/E/S/W at radius 184, four short
       diagonals at radius 114, inner valleys at radius 42) fan into 16 triangles
       from the centre. We fake a 3D folded surface lit from the top-left without
       any blur (VectorDrawable has no blur/shadow filter):
         - base layer = the full star filled mid azure (also fills the facets that
           face sideways to the light, and prevents anti-alias seams between facets)
         - highlight facets (top-left-facing) painted bright cyan on top
         - shadow facets (bottom-right-facing) painted deep blue on top
       Saturated cyan -> deep blue (no violet) to echo Deneb the blue-white star and
       stay distinct from a flat 4-point AI sparkle. Group scale 0.84 keeps the long
       tips inside the adaptive-icon safe zone. -->
  <group android:scaleX="0.84"
      android:scaleY="0.84"
      android:translateX="40.96"
      android:translateY="40.96">
    <!-- base / mid-tone facets (full star, seam-free underlay) -->
    <path
        android:pathData="M256,72 L272.07,217.2 L336.6,175.4 L294.8,239.93 L440,256 L294.8,272.07 L336.6,336.6 L272.07,294.8 L256,440 L239.93,294.8 L175.4,336.6 L217.2,272.07 L72,256 L217.2,239.93 L175.4,175.4 L239.93,217.2 Z"
        android:fillColor="#FF2C84C9"/>
    <!-- highlight facets (lit, top-left) -->
    <path
        android:pathData="M256,256 L256,72 L272.07,217.2 Z M256,256 L217.2,272.07 L72,256 Z M256,256 L72,256 L217.2,239.93 Z M256,256 L217.2,239.93 L175.4,175.4 Z M256,256 L175.4,175.4 L239.93,217.2 Z M256,256 L239.93,217.2 L256,72 Z"
        android:fillColor="#FF5BC8E8"/>
    <!-- shadow facets (bottom-right) -->
    <path
        android:pathData="M256,256 L294.8,239.93 L440,256 Z M256,256 L440,256 L294.8,272.07 Z M256,256 L294.8,272.07 L336.6,336.6 Z M256,256 L336.6,336.6 L272.07,294.8 Z M256,256 L272.07,294.8 L256,440 Z M256,256 L256,440 L239.93,294.8 Z"
        android:fillColor="#FF154B86"/>
  </group>
</vector>
