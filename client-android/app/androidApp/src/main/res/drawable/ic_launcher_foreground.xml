<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="512"
    android:viewportHeight="512">
  <!-- Deneb mark — "hero" rendition of the 4-point sparkle (✦). The status-bar
       notification icon and chat thinking-indicator keep the pure symmetric
       denebSparklePath; this launcher icon is the richer treatment:
         1. soft WHITE radial glow so the navy field reads as real starlight
         2. main sparkle with a luminous core (near-white -> cyan -> sky -> indigo)
         3. gently elongated vertical proportion (graceful, not a plus sign)
         4. a small accent twinkle to the upper-right
       Everything sits in one group (scale 0.84) to stay inside the adaptive-icon
       safe zone. Gradient coordinates are in this group-local (path) space. -->
  <group android:scaleX="0.84"
      android:scaleY="0.84"
      android:translateX="40.96"
      android:translateY="40.96">

    <!-- soft white glow behind the sparkle (radial, fades to transparent) -->
    <path android:pathData="M51,256 a205,205 0 1,0 410,0 a205,205 0 1,0 -410,0 Z">
      <aapt:attr name="android:fillColor">
        <gradient
            android:type="radial"
            android:centerX="256"
            android:centerY="256"
            android:gradientRadius="205">
          <item android:offset="0.0" android:color="#5CFFFFFF"/>
          <item android:offset="0.5" android:color="#1FFFFFFF"/>
          <item android:offset="1.0" android:color="#00FFFFFF"/>
        </gradient>
      </aapt:attr>
    </path>

    <!-- main sparkle: elongated, luminous diagonal gradient -->
    <path android:pathData="M256,74 Q274.3,236 422,256 Q274.3,276 256,438 Q237.7,276 90,256 Q237.7,236 256,74 Z">
      <aapt:attr name="android:fillColor">
        <gradient
            android:type="linear"
            android:startX="110"
            android:startY="110"
            android:endX="410"
            android:endY="410">
          <item android:offset="0.0" android:color="#FFBFEFFA"/>
          <item android:offset="0.28" android:color="#FF66D9E8"/>
          <item android:offset="0.62" android:color="#FF7FA8D0"/>
          <item android:offset="1.0" android:color="#FF9B8CE0"/>
        </gradient>
      </aapt:attr>
    </path>

    <!-- accent twinkle, upper-right -->
    <path
        android:pathData="M368,120 Q371.3,146.7 398,150 Q371.3,153.3 368,180 Q364.7,153.3 338,150 Q364.7,146.7 368,120 Z"
        android:fillColor="#FFCFEFF9"/>
  </group>
</vector>
