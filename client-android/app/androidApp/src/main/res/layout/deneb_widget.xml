<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="16dp"
    android:gravity="center_vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Deneb"
        android:textColor="@color/widget_accent"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.08" />

    <!-- Next meeting: calendar glyph + title/time -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_widget_calendar"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/widget_meeting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="…"
            android:textColor="@color/widget_title"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="-0.01"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Recent mail: envelope glyph + "sender · subject", with the unread count as
         a sub-line. The whole row is hidden when there is no mail to show. -->
    <LinearLayout
        android:id="@+id/widget_mail_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginTop="1dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_widget_mail"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_mail_latest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/widget_subtitle"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_mail_unread"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text=""
                android:textColor="@color/widget_meta"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
