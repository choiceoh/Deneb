{
  "permissions": {
    "allow": [
      "Bash(make *)",
      "Bash(cargo *)",
      "Bash(go *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git pull*)",
      "Bash(git push*)",
      "Bash(git rev-parse*)",
      "Bash(git rev-list*)",
      "Bash(git show*)",
      "Bash(git stash list*)",
      "Bash(git remote*)",
      "Bash(git check-ignore*)",
      "Bash(git update-ref*)",
      "Bash(scripts/*)",
      "Bash(gh pr *)",
      "Bash(gh run *)",
      "Bash(gh issue *)",
      "Bash(gh api *)",
      "Bash(gh auth status*)",
      "Bash(buf *)",
      "Bash(protoc *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(pgrep *)",
      "Bash(ss -ltnp*)",
      "Bash(cat /tmp/deneb-*.log*)",
      "Bash(tail /tmp/deneb-*.log*)",
      "Bash(wc *)",
      "Read(/home/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/setup-dev-env.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit-gate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitWorktree",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/worktree-auto-pr.sh"
          }
        ]
      }
    ]
  }
}
