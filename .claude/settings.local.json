{
  "permissions": {
    "allow": [
      "Bash(make *)",
      "Bash(cargo *)",
      "Bash(go *)",
      "Bash(git check-ignore:*)",
      "Bash(echo \"exit: $?\")",
      "Read(//home/user/**)",
      "Read(//home/**)",
      "Bash(git checkout:*)",
      "Bash(scripts/committer \"fix\\(devenv\\): remove hardcoded /home/user/Deneb paths for portability\" .claude/settings.local.json scripts/setup-dev-env.sh)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/setup-dev-env.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitWorktree",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/worktree-auto-pr.sh"
          }
        ]
      }
    ]
  }
}
