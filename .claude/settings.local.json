{
  "permissions": {
    "allow": [
      "Bash(make *)",
      "Bash(cargo *)",
      "Bash(go *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/user/Deneb && ./scripts/setup-dev-env.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitWorktree",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/worktree-auto-pr.sh"
          }
        ]
      }
    ]
  }
}
