    "required": [
      "action"
    ]
  },
  {
    "name": "web",
    "properties": {
      "mode": {
        "type": "string",
        "description": "Mode: search (web search/fetch, default), request (raw HTTP for APIs), research (deep multi-query research)",
        "enum": [
          "search",
          "request",
          "research"
        ],
        "default": "search"
      },
      "url": {
        "type": "string",
        "description": "URL to fetch (search mode: HTML extraction+bot evasion; request mode: raw HTTP)"
      },
      "query": {
        "type": "string",
        "description": "Web search query (search mode). Perplexity Sonar > Brave > DuckDuckGo fallback"
      },
      "queries": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Multiple queries: parallel search (search mode, max 5) or pre-decomposed sub-queries (research mode)"
      },
      "fetch": {
        "type": "number",
        "description": "Auto-fetch top N results per query (search mode, 1-3, default: 0)"
      },
      "maxChars": {
        "type": "number",
        "description": "Maximum content characters total (default: 50000)"
      },
      "count": {
        "type": "number",
        "description": "Number of search results per query (search mode, default: 5)"
      },
      "method": {
        "type": "string",
        "description": "HTTP method (request mode only)",
        "enum": [
          "GET",
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ],
        "default": "GET"
      },
      "headers": {
        "type": "object",
        "description": "Request headers (request mode only)",
        "additionalProperties": true
      },
      "body": {
        "type": "string",
        "description": "Request body string (request mode only)"
      },
      "json": {
        "type": "object",
        "description": "JSON body, auto-sets Content-Type (request mode only)",
        "additionalProperties": true
      },
      "timeout": {
        "type": "number",
        "description": "Timeout in seconds (request mode, default: 30)",
        "default": 30,
        "minimum": 1,
        "maximum": 120
      },
      "max_response_chars": {
        "type": "number",
        "description": "Max response chars (request mode, default: 50000)",
        "default": 50000
      },
      "question": {
        "type": "string",
        "description": "Research question (research mode). Auto-decomposes into parallel sub-queries"
      },
      "maxQueries": {
        "type": "number",
        "description": "Max sub-queries to generate (research mode, default: 5, max: 8)"
      },
      "fetchPerQuery": {
        "type": "number",
        "description": "Pages to auto-fetch per sub-query (research mode, default: 2, max: 3)"
      }
    }
  },
  {
    "name": "health_check",
    "properties": {
      "component": {
        "type": "string",
        "enum": [
          "all",
          "localai"
        ],
        "description": "Component to check (default: all). localai=local LLM"
      }
    }
  },
  {
    "name": "cron",
    "description": "Manage scheduled tasks (cron jobs). Actions: add (create), list (all jobs), status (service health),\nget (job detail), update (modify), remove (delete), run (execute now), runs (execution history).\nSchedule formats: cron expression (0 9 * * * = daily 9am), interval (30m, 1h), one-shot (ISO timestamp).\nCommon patterns: 0 9 * * * (daily 9am), 0 */2 * * * (every 2h), 0 9 * * 1-5 (weekdays 9am), @daily, @hourly.\n",
    "properties": {
      "action": {
        "type": "string",
        "description": "Cron action",
        "enum": [
          "status",
          "list",
          "add",
          "update",
          "remove",
          "run",
          "get",
          "runs",
          "wake"
        ]
      },
      "name": {
        "type": "string",
        "description": "Job name (required for add, used as job ID)"
      },
      "schedule": {
        "type": "string",
        "description": "Schedule specification. Formats: cron (0 9 * * *), interval (1h, 30m, every 5m), timestamp (2026-04-06T08:00:00), shorthand (@daily, @hourly, @weekly)"
      },
      "command": {
        "type": "string",
        "description": "Agent message/command to execute on schedule (required for add)"
      },
      "jobId": {
        "type": "string",
        "description": "Job ID for get/update/remove/run/runs actions"
      },
      "enabled": {
        "type": "boolean",
        "description": "Enable or disable a job (for add/update)"
      },
      "limit": {
        "type": "integer",
        "description": "Max entries to return (for runs action, default 10)"
      },
      "tz": {
        "type": "string",
        "description": "Timezone for cron schedules (e.g. Asia/Seoul, UTC). Defaults to system local timezone"
      },
      "staggerMs": {
        "type": "integer",
        "description": "Random delay window in ms to distribute cron jobs (cron kind only, default: auto for top-of-hour)"
      },
      "anchorTime": {
        "type": "string",
        "description": "Anchor time for interval schedules (ISO 8601). Intervals count from this time instead of registration time"
      },
      "retryCount": {
        "type": "integer",
        "description": "Number of retry attempts on failure (0-3, default 0 = no retry)"
      },
      "retryBackoffMs": {
        "type": "integer",
        "description": "Initial backoff delay between retries in ms (default 5000). Doubles each retry, capped at 60s"
      },
      "deliveryMode": {
        "type": "string",
        "description": "How to deliver output: announce (send to Telegram, default) or none (run silently)",
        "enum": [
          "announce",
          "none"
        ]
      },
      "job": {
        "type": "object",
        "description": "Job definition object (alternative to top-level name/schedule/command)",
        "additionalProperties": true
      },
      "text": {
        "type": "string",
        "description": "System event text for wake action"
      }
    },
    "required": [
      "action"
    ]
  },
  {
    "name": "message",
