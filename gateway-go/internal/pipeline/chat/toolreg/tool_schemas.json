        "default": false
      },
      "force": {
        "type": "boolean",
        "description": "Force clean (-f). Required when dry_run is false",
        "default": false
      },
      "short": {
        "type": "boolean",
        "description": "Short status format",
        "default": false
      }
    },
    "required": [
      "action"
    ]
  },
  {
    "name": "exec",
    "max_output": 51200,
    "properties": {
      "command": {
        "type": "string",
        "description": "Shell command to execute"
      },
      "workdir": {
        "type": "string",
        "description": "Working directory (defaults to workspace root)"
      },
      "timeout": {
        "type": "number",
        "description": "Timeout in seconds (default: 60, max: 600)",
        "default": 60,
        "minimum": 1,
        "maximum": 600
      },
      "background": {
        "type": "boolean",
        "description": "Run in background immediately, then use process tool to check output",
        "default": false
      },
      "structured": {
        "type": "boolean",
        "description": "Return JSON with stdout, stderr, exit_code, runtime_ms instead of plain text",
        "default": false
      },
      "env": {
        "type": "object",
        "description": "Environment variables to set for this command (key-value pairs). Blocked keys (API keys, secrets) are filtered.",
        "additionalProperties": {
          "type": "string"
        }
      }
    },
    "required": [
      "command"
    ]
  },
  {
    "name": "process",
