        "default": false
      },
      "create": {
        "type": "boolean",
        "description": "Create a new branch",
        "default": false
      },
      "from": {
        "type": "string",
        "description": "Base ref for branch creation"
      },
      "file": {
        "type": "string",
        "description": "File path for blame"
      },
      "start_line": {
        "type": "number",
        "description": "Start line for blame range"
      },
      "end_line": {
        "type": "number",
        "description": "End line for blame range"
      },
      "stash_action": {
        "type": "string",
        "description": "Stash sub-action",
        "enum": [
          "push",
          "pop",
          "list",
          "drop",
          "apply"
        ]
      },
      "branch": {
        "type": "string",
        "description": "Branch to merge"
      },
      "no_ff": {
        "type": "boolean",
        "description": "No fast-forward merge",
        "default": false
      },
      "abort": {
        "type": "boolean",
        "description": "Abort in-progress merge/rebase/cherry-pick",
        "default": false
      },
      "continue_op": {
        "type": "boolean",
        "description": "Continue in-progress rebase/cherry-pick",
        "default": false
      },
      "onto": {
        "type": "string",
        "description": "Rebase onto target ref"
      },
      "ref": {
        "type": "string",
        "description": "Git ref for cherry-pick or reset"
      },
      "mode": {
        "type": "string",
        "description": "Reset mode: soft, mixed (default), hard",
        "enum": [
          "soft",
          "mixed",
          "hard"
        ]
      },
      "remote_action": {
        "type": "string",
        "description": "Remote sub-action: list (default), add, remove",
        "enum": [
          "list",
          "add",
          "remove"
        ]
      },
      "url": {
        "type": "string",
        "description": "Remote URL for add"
      },
      "dry_run": {
        "type": "boolean",
        "description": "Show what would be removed without actually removing (clean)",
        "default": true
      },
      "directories": {
        "type": "boolean",
