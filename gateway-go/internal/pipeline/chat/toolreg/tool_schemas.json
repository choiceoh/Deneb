    ]
  },
  {
    "name": "git",
    "properties": {
      "action": {
        "type": "string",
        "description": "Git action to perform",
        "enum": [
          "status",
          "commit",
          "log",
          "branch",
          "stash",
          "blame",
          "tag",
          "merge",
          "rebase",
          "cherry_pick",
          "reset",
          "remote",
          "clean"
        ]
      },
      "message": {
        "type": "string",
        "description": "Commit message (commit), stash message (stash push), tag annotation (tag)"
      },
      "files": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Files to stage before commit. Empty = commit currently staged files"
      },
      "all": {
        "type": "boolean",
        "description": "Stage all tracked changes before commit (git commit -a)",
        "default": false
      },
      "amend": {
        "type": "boolean",
        "description": "Amend the last commit",
        "default": false
      },
      "count": {
        "type": "number",
        "description": "Number of log entries (default: 10, max: 50)",
        "default": 10,
        "minimum": 1,
        "maximum": 50
      },
      "oneline": {
        "type": "boolean",
        "description": "One-line log format",
        "default": false
      },
      "author": {
        "type": "string",
        "description": "Filter log by author"
      },
      "since": {
        "type": "string",
        "description": "Filter log since date (e.g. '2024-01-01', '1 week ago')"
      },
      "path": {
        "type": "string",
        "description": "File path for log/blame"
      },
      "grep": {
        "type": "string",
        "description": "Filter log by commit message grep pattern"
      },
      "name": {
        "type": "string",
        "description": "Branch/tag/remote name"
      },
      "delete": {
        "type": "boolean",
        "description": "Delete the named branch/tag",
        "default": false
      },
      "switch_to": {
        "type": "boolean",
