  {
    "name": "gateway",
    "properties": {
      "action": {
        "type": "string",
        "description": "Gateway action",
        "enum": [
          "restart",
          "config.get",
          "config.schema.lookup",
          "config.apply",
          "config.patch",
          "update.run"
        ]
