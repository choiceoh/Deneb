#!/usr/bin/env bash
# Pre-commit hook: run basic checks before committing.
set -euo pipefail

# Rust format check (if core-rs or cli-rs files are staged)
if git diff --cached --name-only | grep -qE '^(core-rs|cli-rs)/'; then
  echo "[pre-commit] Checking Rust formatting..."
  (cd core-rs && cargo fmt --all -- --check) || { echo "Rust format check failed. Run: cd core-rs && cargo fmt --all"; exit 1; }
  (cd cli-rs && cargo fmt -- --check) || { echo "CLI Rust format check failed. Run: cd cli-rs && cargo fmt"; exit 1; }
fi

# Go vet (if gateway-go files are staged)
if git diff --cached --name-only | grep -q '^gateway-go/'; then
  echo "[pre-commit] Running Go vet..."
  (cd gateway-go && go vet ./...) || { echo "Go vet failed."; exit 1; }
fi
