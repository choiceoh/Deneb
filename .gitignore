# Mini App embedded assets: only placeholder.html is checked in. The real
# bundle (index.html + assets/) is generated by `make embed-frontend` and
# served at runtime; if it is missing the static handler falls back to
# placeholder.html, so `go build` always works on a fresh clone.
gateway-go/internal/runtime/server/miniapp_dist/index.html
gateway-go/internal/runtime/server/miniapp_dist/assets/
gateway-go/internal/runtime/server/miniapp_dist/*.svg
gateway-go/internal/runtime/server/miniapp_dist/*.ico
gateway-go/internal/runtime/server/miniapp_dist/*.png
gateway-go/internal/runtime/server/miniapp_dist/*.jpg
gateway-go/internal/runtime/server/miniapp_dist/*.json

